{
  "name": "magpie-bot",
  "version": "0.1.0",
  "description": "Discord bot that collects and classifies URLs into Karakeep",
  "type": "module",
  "packageManager": "yarn@4.13.0",
  "scripts": {
    "dev": "tsx --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "prepare": "husky"
  },
  "dependencies": {
