    "discord.js": "^14",
    "zod": "^3"
  },
  "devDependencies": {
    "@types/node": "^20",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "pretty-quick": "^4.2.2",
    "tsx": "^4",
    "typescript": "^5"
  }
