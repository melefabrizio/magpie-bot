# Discord
DISCORD_TOKEN=           # Bot token from https://discord.com/developers/applications
CHANNEL_IDS=             # Comma-separated channel IDs to monitor, e.g. 123456789,987654321

# Karakeep
KARAKEEP_API_URL=        # e.g. https://your-karakeep-instance/api/v1
KARAKEEP_API_KEY=        # API key from your Karakeep instance

# AWS Bedrock (used for classification via AI SDK)
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# or
AWS_PROFILE=

# Classifier
# CLASSIFY_SYSTEM_PROMPT=  # Override the LLM system prompt for link classification
